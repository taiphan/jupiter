# Copy to .env for docker compose overrides (optional).
# Defaults in docker-compose.yml are enough for local OrbStack deploy.

# POSTGRES_HOST_PORT=15432
# Host tools (psql, GUI): postgresql://jupiter:jupiter@localhost:15432/jupiter
# DATABASE_URL=postgresql://jupiter:jupiter@postgres:5432/jupiter
# Vercel Supabase integration provides POSTGRES_URL (used automatically if DATABASE_URL is unset)
# NODE_ENV=production

# --- Auth (email + Google) ---
APP_URL=http://localhost:3100
AUTH_SECRET=change-me-in-production
EMAIL_PROVIDER=console
# Defaults when using Settings → Authentication (or env bootstrap):
# EMAIL_FROM=taiphantuan@gmail.com
# MAIL_REDIRECT_TO=taiphantuan@gmail.com
# TEST_EMAIL_TO=taiphantuan@gmail.com

# --- Gmail SMTP (v1.10) — sends verify/reset email; use App Password, not your login password ---
# EMAIL_PROVIDER=gmail
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=taiphantuan@gmail.com
# SMTP_PASS=your-16-char-app-password
# EMAIL_FROM=Jupiter <taiphantuan@gmail.com>
# Generic SMTP_URL also supported: smtp://user:pass@smtp.example.com:587

# --- TOTP 2FA (v1.10) ---
# AUTH_2FA_ENABLED=true

# --- Auth breadth (v1.11) — see docs/v2.0-auth-enterprise-breadth-requirements.md ---
# AUTH_MICROSOFT_ENABLED=false
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# AUTH_MICROSOFT_TENANT_ID=common
# AUTH_GITHUB_ENABLED=false
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- Enterprise identity (v2.0) ---
# AUTH_SAML_ENABLED=false
# AUTH_OIDC_ENABLED=false
# AUTH_SCIM_ENABLED=false
# AUTH_BREAK_GLASS_EMAILS=ops@company.com

# Set true, or omit and rely on client ID + secret (auto-enables when both are set)
AUTH_GOOGLE_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google Console redirect URI: http://localhost:3100/api/auth/google/callback
# Optional: restrict sign-in to a Google Workspace domain
# GOOGLE_ALLOWED_HD=yourcompany.com
