{
  "name": "jupiter",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3100",
    "build": "docker compose build",
    "build:app": "next build",
    "deploy": "docker compose up -d --build",
    "deploy:down": "docker compose down",
    "deploy:logs": "docker compose logs -f app",
    "db:push": "docker compose --profile tools run --rm db-push",
    "db:seed": "docker compose --profile tools run --rm db-seed",
    "db:setup": "npm run db:push && npm run db:seed",
    "start": "docker compose up -d",
    "start:app": "next start -p 3100",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "shadcn": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "tiny-invariant": "^1.3.3",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "fast-check": "^3.23.2",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
